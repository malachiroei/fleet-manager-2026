{
  "headers": [
    {
      "source": "/app-icon-192.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/app-icon-512.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/site.webmanifest(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/app-icon-512.png" },
    { "source": "/favicon.png", "destination": "/app-icon-512.png" },
    {
      "source": "/((?!assets/).*)",
      "destination": "/"
    }
  ]
}
